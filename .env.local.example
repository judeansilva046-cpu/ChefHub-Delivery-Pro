# Supabase Configuration
# Copie este arquivo para .env.local e preencha com suas credenciais

# URL do seu projeto Supabase
# Disponível em: https://app.supabase.com/project/[seu-projeto]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave pública do Supabase (anon key)
# Disponível em: https://app.supabase.com/project/[seu-projeto]/settings/api
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Environment
NODE_ENV=development

# (Opcional) URL pública da aplicação
# Usar apenas para deploy em produção
# NEXT_PUBLIC_APP_URL=https://seu-app.vercel.app
